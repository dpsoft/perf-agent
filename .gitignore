### Go ###
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with go test -c
*.test

# Output of the go profiling tool
*.prof

# Output of the go coverage tool
*.out

# Compiled Object files, Static and Dynamic libs (Shared Objects)
*.o
# Note: eBPF bytecode files (*_bpfel.o, *_bpfeb.o) are committed for library usage
!*_bpfel.o
!*_bpfeb.o
# Committed test fixtures (cross-compiled arm64 object file for CFI tests)
!unwind/ehcompile/testdata/*.o
*.a

# Go generated folders
_obj
_test
vendor

# Architecture specific extensions/prefixes
*.[568vq]

# CGO specific files
*.cgo1.go
*.cgo2.c
_cgo_defun.c
_cgo_gotypes.go
_cgo_export.*

# Common IDE folders
.idea
.vscode
.env
.cursor/**

### Rust ###
# Cargo build artifacts
**/target/
.fingerprint
*.pdb

### Test artifacts ###
# Profile outputs
*.pb.gz
profile.pb.gz
offcpu.pb.gz

# Python perf maps
/tmp/perf-*.map

# Test temporary files
/tmp/perf-agent-test-*

# Built test workload binaries (sources are tracked; binaries aren't)
test/workloads/go/cpu_bound
test/workloads/go/io_bound

### Local dev runtime debris ###
# Node.js V8 isolate logs from JS workload runs
isolate-*-v8.log

# Stray PMU capture files some users redirect from the CLI
pmu.txt

# Codex / Anthropic CLI cache
.codex

### Project binaries ###
perf-agent
bench/cmd/scenario/scenario
bench/cmd/report/report

### Benchmark artifacts ###
bench-*.json
bench-report.md

### Anthropic Claude ###
# Track project-shared Claude config (.claude/settings.json) but keep
# per-user / per-machine state out of the repo.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.log
.memory-bank

### Git worktrees ###
.worktrees/

# debuginfod local cache (created by upload.sh during tests)
test/debuginfod/debuginfo-store/
# Compiled sample binaries (sources are tracked; binaries are not)
test/debuginfod/sample/hello
test/debuginfod/sample/hello.full
test/debuginfod/sample/hello.debug
